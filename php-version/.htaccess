# =============================================================================
# Maventech Admin Panel — Apache hardening (cPanel / Plesk / shared hosting)
# =============================================================================

# ---- Force UTF-8 ----
AddDefaultCharset UTF-8

# ---- Block direct access to sensitive files ----
<FilesMatch "^(database\.sql|start\.sh|seed-templates\.php|router\.php|composer\.(json|lock))$">
    Require all denied
</FilesMatch>

# ---- Block dotfiles and backup files ----
<FilesMatch "^\.(env|git|htaccess|htpasswd|DS_Store)|~$|\.bak$|\.old$|\.swp$">
    Require all denied
</FilesMatch>

# ---- Block direct access to the includes/ and lib/ directories ----
RedirectMatch 404 ^/includes/
RedirectMatch 404 ^/lib/
RedirectMatch 404 ^/vendor/

# ---- Block raw access to customer-PII PDFs (receipts/invoices).
#      These must only be served via order-history.php which checks
#      the email + order-number session unlock. ----
RewriteEngine On
RewriteRule ^uploads/order-pdfs/.* - [F,L]

# ---- Disable PHP / shell execution inside uploads/ ----
<Directory "uploads">
    <FilesMatch "\.(php|phtml|phar|sh|cgi|pl)$">
        Require all denied
    </FilesMatch>
</Directory>

# ---- Security headers ----
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ---- Disable directory listing ----
Options -Indexes

# ---- Pretty error page for 404 ----
ErrorDocument 404 /404.php

# ---- Gzip compression ----
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/xml application/xml application/rss+xml image/svg+xml
</IfModule>

# ---- Static-asset cache (1 year) ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
